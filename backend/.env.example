# Copy to .env and adjust
DATABASE_URL=postgresql+psycopg://f1app:f1app_dev_password@localhost:5432/f1_insight
DEBUG=false

# Comma-separated browser origins allowed to call the API (CORS).
# In production set this to your deployed frontend, e.g.
#   CORS_ORIGINS=https://racecraft.vercel.app
CORS_ORIGINS=http://localhost:3000

# Secret used to sign login tokens. MUST be a long random string in production.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production

# Optional — activates the Claude insights provider when set
# ANTHROPIC_API_KEY=sk-ant-...
